T*
(-- Auto-create profile when user signs up) Tj
T*
(CREATE OR REPLACE FUNCTION public.handle_new_user\(\)) Tj
T*
(RETURNS TRIGGER AS $$) Tj
T*
(BEGIN) Tj
T*
(  INSERT INTO public.profiles \(id, email, full_name, role, created_at\)) Tj
T*
(  VALUES \() Tj
T*
(    NEW.id,) Tj
ET
