(-- 1. TABLES) Tj
T*
(-- =====================) Tj
T*
() Tj
T*
(-- Profiles \(extends auth.users\)) Tj
T*
(CREATE TABLE public.profiles \() Tj
T*
(  id           uuid PRIMARY KEY REFERENCES auth.users\(id\) ON DELETE CASCADE,) Tj
T*
(  email        text NOT NULL UNIQUE,) Tj
T*
(  full_name    text,) Tj
T*
(  avatar_url   text,) Tj
T*
(  role         text NOT NULL DEFAULT 'student' CHECK \(role IN \('student','admin'\)\),) Tj
T*
(  about        text,) Tj
T*
(  points       integer NOT NULL DEFAULT 0,) Tj
T*
(  warnings     integer NOT NULL DEFAULT 0,) Tj
T*
(  is_banned    boolean NOT NULL DEFAULT false,) Tj
T*
(  created_at   timestamptz NOT NULL DEFAULT now\(\),) Tj
T*
(  updated_at   timestamptz NOT NULL DEFAULT now\(\)) Tj
T*
(\);) Tj
T*
(CREATE INDEX idx_profiles_role         ON public.profiles\(role\);) Tj
T*
(CREATE INDEX idx_profiles_points_desc  ON public.profiles\(points DESC\);) Tj
T*
() Tj
T*
(-- Groups) Tj
T*
(CREATE TABLE public.groups \() Tj
T*
(  id           uuid PRIMARY KEY DEFAULT gen_random_uuid\(\),) Tj
T*
(  name         text NOT NULL,) Tj
T*
(  description  text,) Tj
T*
(  join_code    text NOT NULL UNIQUE,) Tj
T*
(  created_by   uuid NOT NULL REFERENCES public.profiles\(id\),) Tj
T*
(  created_at   timestamptz NOT NULL DEFAULT now\(\)) Tj
T*
(\);) Tj
T*
() Tj
T*
(-- Group Members \(many-to-many\)) Tj
T*
(CREATE TABLE public.group_members \() Tj
T*
(  group_id   uuid NOT NULL REFERENCES public.groups\(id\)   ON DELETE CASCADE,) Tj
T*
(  user_id    uuid NOT NULL REFERENCES public.profiles\(id\) ON DELETE CASCADE,) Tj
T*
(  joined_at  timestamptz NOT NULL DEFAULT now\(\),) Tj
T*
(  PRIMARY KEY \(group_id, user_id\)) Tj
T*
(\);) Tj
T*
() Tj
T*
(-- Messages \(chat\)) Tj
T*
(CREATE TABLE public.messages \() Tj
T*
(  id          uuid PRIMARY KEY DEFAULT gen_random_uuid\(\),) Tj
T*
(  group_id    uuid NOT NULL REFERENCES public.groups\(id\)   ON DELETE CASCADE,) Tj
T*
(  sender_id   uuid NOT NULL REFERENCES public.profiles\(id\) ON DELETE CASCADE,) Tj
T*
(  content     text,) Tj
T*
(  file_url    text,) Tj
T*
(  file_name   text,) Tj
T*
(  file_type   text,) Tj
T*
(  created_at  timestamptz NOT NULL DEFAULT now\(\)) Tj
T*
(\);) Tj
T*
(CREATE INDEX idx_messages_group_time ON public.messages\(group_id, created_at DESC\);) Tj
T*
() Tj
T*
(-- Notes) Tj
T*
(CREATE TABLE public.notes \() Tj
ET
