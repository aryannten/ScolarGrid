40 792 Td
(    NEW.email,) Tj
T*
(    COALESCE\(NEW.raw_user_meta_data->>'full_name', ''\),) Tj
T*
(    COALESCE\(NEW.raw_user_meta_data->>'role', 'student'\),) Tj
T*
(    NOW\(\)) Tj
T*
(  \);) Tj
T*
(  RETURN NEW;) Tj
T*
(END;) Tj
T*
($$ LANGUAGE plpgsql SECURITY DEFINER;) Tj
T*
() Tj
T*
(CREATE TRIGGER on_auth_user_created) Tj
T*
(  AFTER INSERT ON auth.users) Tj
T*
(  FOR EACH ROW EXECUTE FUNCTION public.handle_new_user\(\);) Tj
T*
() Tj
T*
(-- Auto-update updated_at timestamp) Tj
T*
(CREATE OR REPLACE FUNCTION public.set_updated_at\(\)) Tj
T*
(RETURNS TRIGGER AS $$) Tj
T*
(BEGIN) Tj
T*
(  NEW.updated_at = now\(\);) Tj
T*
(  RETURN NEW;) Tj
T*
(END;) Tj
T*
($$ LANGUAGE plpgsql;) Tj
T*
() Tj
T*
(CREATE TRIGGER trg_profiles_updated_at) Tj
T*
(  BEFORE UPDATE ON public.profiles) Tj
T*
(  FOR EACH ROW EXECUTE FUNCTION public.set_updated_at\(\);) Tj
T*
() Tj
T*
(CREATE TRIGGER trg_complaints_updated_at) Tj
T*
(  BEFORE UPDATE ON public.complaints) Tj
T*
(  FOR EACH ROW EXECUTE FUNCTION public.set_updated_at\(\);) Tj
T*
() Tj
T*
(-- Award 10 points when a note is uploaded) Tj
T*
(CREATE OR REPLACE FUNCTION public.award_points_on_note_upload\(\)) Tj
T*
(RETURNS TRIGGER AS $$) Tj
T*
(BEGIN) Tj
T*
(  INSERT INTO public.leaderboard_points \(user_id, points, reason, reference_id\)) Tj
T*
(  VALUES \(NEW.uploader_id, 10, 'note_upload', NEW.id\);) Tj
T*
() Tj
T*
(  UPDATE public.profiles) Tj
T*
(  SET points = points + 10) Tj
T*
(  WHERE id = NEW.uploader_id;) Tj
T*
() Tj
T*
(  RETURN NEW;) Tj
T*
(END;) Tj
T*
($$ LANGUAGE plpgsql SECURITY DEFINER;) Tj
T*
() Tj
T*
(CREATE TRIGGER trg_award_points_note_upload) Tj
T*
(  AFTER INSERT ON public.notes) Tj
T*
(  FOR EACH ROW EXECUTE FUNCTION public.award_points_on_note_upload\(\);) Tj
T*
() Tj
T*
() Tj
T*
