# ══════════════════════════════════════════════════════
#  ScholarGrid Backend API — Production Environment
#  Copy this file to .env and fill in your production values.
# ══════════════════════════════════════════════════════

# ── Application ─────────────────────────────────────
APP_NAME="ScholarGrid Backend API"
APP_VERSION="0.1.0"
ENVIRONMENT=production

# CRITICAL: Generate a secure random key (min 32 chars)
# Example: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=REPLACE_WITH_SECURE_RANDOM_KEY_MIN_32_CHARS

# ── Database (PostgreSQL) ────────────────────────────
# Production database connection string
# Format: postgresql+psycopg://USER:PASS@HOST:PORT/DBNAME
# Example: postgresql+psycopg://scholargrid:secure_password@db.example.com:5432/scholargrid
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME

# ── Redis ─────────────────────────────────────────────
# Production Redis connection string
# Format: redis://HOST:PORT/DB
# Example: redis://redis.example.com:6379/0
# For Redis with password: redis://:PASSWORD@HOST:PORT/DB
REDIS_URL=redis://HOST:6379/0

# ── Firebase Admin SDK ────────────────────────────────
# Path to the service account JSON file downloaded from Firebase console
# In production, mount this file securely (e.g., Kubernetes secret, Docker volume)
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json

# ── Google Gemini API ─────────────────────────────────
# REQUIRED: Get your API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_API_KEY

# ── CORS Origins ──────────────────────────────────────
# Comma-separated list of allowed frontend origins (HTTPS only in production)
# Example: https://app.example.com,https://www.example.com
CORS_ORIGINS=https://your-frontend-domain.com

# ── Rate Limiting ─────────────────────────────────────
# Maximum requests per user per minute
RATE_LIMIT=100

# ── Cloudinary (File Storage) ─────────────────────────
# Get credentials from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Error Tracking (Optional) ─────────────────────────
# Sentry DSN for error tracking and monitoring
# Get from https://sentry.io/settings/projects/
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ── Monitoring (Optional) ─────────────────────────────
# Enable Prometheus metrics endpoint
# ENABLE_METRICS=true

# ── Logging ───────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Production default: INFO
# LOG_LEVEL=INFO

# ══════════════════════════════════════════════════════
#  PRODUCTION CHECKLIST
# ══════════════════════════════════════════════════════
# 
# Before deploying to production, ensure:
# 
# ✓ SECRET_KEY is a secure random string (min 32 chars)
# ✓ DATABASE_URL points to production database (not localhost)
# ✓ REDIS_URL points to production Redis (not localhost)
# ✓ FIREBASE_CREDENTIALS_PATH is correctly mounted
# ✓ GEMINI_API_KEY is set and valid
# ✓ CORS_ORIGINS contains only HTTPS URLs (no localhost)
# ✓ All passwords are strong and unique
# ✓ Firebase credentials file is securely stored
# ✓ Database backups are configured
# ✓ SSL/TLS certificates are valid
# ✓ Firewall rules are configured
# ✓ Monitoring and alerting are set up
# 
# ══════════════════════════════════════════════════════
