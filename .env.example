# ══════════════════════════════════════════════════════
#  ScholarGrid Backend API — Environment Variables
#  Copy this file to .env and fill in your values.
# ══════════════════════════════════════════════════════

# ── Application ─────────────────────────────────────
APP_NAME="ScholarGrid Backend API"
APP_VERSION="0.1.0"
ENVIRONMENT=development           # development | production

# Secret key used for signing tokens (min 32 chars in production)
SECRET_KEY=dev-secret-key-change-in-production

# ── Database (PostgreSQL) ────────────────────────────
# Format: postgresql+psycopg://USER:PASS@HOST:PORT/DBNAME
DATABASE_URL=postgresql+psycopg://scholargrid:scholargrid_pass@localhost:5432/scholargrid

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Firebase Admin SDK ────────────────────────────────
# Path to the service account JSON file downloaded from Firebase console
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# ── Google Gemini API ─────────────────────────────────
# Get your API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── CORS Origins ──────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Rate Limiting ─────────────────────────────────────
# Maximum requests per user per minute
RATE_LIMIT=100
